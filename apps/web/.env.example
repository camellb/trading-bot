# apps/web/.env.example - Vercel project environment.
#
# Copy to .env.local for local development. On Vercel, set each variable in
# Project Settings -> Environment Variables (scope: Production + Preview).
#
# Next.js reads .env files automatically. NEXT_PUBLIC_* values are shipped
# to the client bundle. Never put secrets behind that prefix.

# --- Required --------------------------------------------------------------

# Supabase Postgres connection string. For the Vercel deployment use the
# "Connection Pooling" URI (port 6543). RLS is enforced through the
# anon/authenticated key flow. The web app must NOT use the service role.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres

# Bot HTTP API base URL. On Vercel, set this to the Railway public domain
# of the bot service (e.g. https://delfi-bot.up.railway.app). Locally, the
# bot runs on 127.0.0.1:8765.
BOT_API_URL=https://delfi-bot.up.railway.app

# Shared secret for dashboard -> bot HTTP auth. Must match BOT_API_SECRET
# in apps/bot. Generate with `openssl rand -base64 32`.
BOT_API_SECRET=

# Supabase project URL + anon key. Used by @supabase/ssr for session cookies,
# route gating in proxy.ts, and server actions in app/auth/actions.ts.
# Find these in Supabase dashboard -> Project Settings -> API.
# Project ref for this deployment: hvlbvbocgncgkkmawigu
NEXT_PUBLIC_SUPABASE_URL=https://hvlbvbocgncgkkmawigu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend API key. Used by server actions that send transactional mail
# (support form, future signup/churn flows). Get it from resend.com ->
# API Keys. The sending domain (delfibot.com) must be verified in Resend
# for sends to succeed.
RESEND_API_KEY=

# --- Stripe + license -----------------------------------------------------
#
# Stripe Checkout drives all paid sales. The webhook at
# /api/webhooks/stripe verifies events, signs an Ed25519 license blob, and
# emails it to the buyer via Resend. See app/api/webhooks/stripe/route.ts
# for the full flow.

# Stripe API keys. From Stripe dashboard -> Developers -> API keys.
# Use sk_test_... in Preview deployments, sk_live_... in Production.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret. From Stripe -> Developers -> Webhooks
# -> the endpoint you added for /api/webhooks/stripe -> "Signing secret".
# Each environment (test vs live) has its own secret.
STRIPE_WEBHOOK_SECRET=

# Public Stripe Checkout URL the marketing site CTAs route to. Get this
# by creating a Payment Link in Stripe -> Payment links. Falls back to
# a mailto in code when unset (so the site doesn't break before Stripe
# is wired).
NEXT_PUBLIC_CHECKOUT_URL=

# Ed25519 private signing key for license blobs (PEM, PKCS8). Generate
# with `node scripts/generate-license-keypair.mjs` from apps/web/, then
# paste the contents of .keys/license-private.pem here. The matching
# public key is embedded in the desktop app's verifier.
#
# Vercel sometimes mangles literal newlines on paste. The loader accepts
# the PEM either inline (literal or escaped \n) or base64-wrapped.
LICENSE_SIGNING_KEY=

# Direct download URLs included in the post-purchase email. Set these
# to the public binary URLs once code-signed builds are live (e.g.
# delfi-mac-arm64-1.0.0.dmg on a CDN). Leave unset to fall back to the
# GitHub Releases page.
# DOWNLOAD_URL_MAC=
# DOWNLOAD_URL_WIN=

# --- Optional -------------------------------------------------------------

# Shows a "Simulation mode" banner in the UI. Default: false.
# NEXT_PUBLIC_PAPER_MODE=true

# --- Analytics (all optional; each loader no-ops when its ID is unset) ----

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX).
# From GA4 Admin -> Data Streams -> Web stream.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID (numeric, ~15 digits).
# From Meta Events Manager -> your Pixel -> Pixel ID.
# NEXT_PUBLIC_META_PIXEL_ID=1234567890

# Microsoft Clarity project ID (10-char string).
# Heatmaps + session replay. Free, unlimited.
# From clarity.microsoft.com -> your project -> Settings -> Project ID.
# NEXT_PUBLIC_CLARITY_ID=a1b2c3d4e5

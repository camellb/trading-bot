# apps/web/.env.example - Vercel project environment.
#
# Copy to .env.local for local development. On Vercel, set each variable in
# Project Settings -> Environment Variables (scope: Production + Preview).
#
# Next.js reads .env files automatically. NEXT_PUBLIC_* values are shipped
# to the client bundle. Never put secrets behind that prefix.

# --- Required --------------------------------------------------------------

# Supabase Postgres connection string. For the Vercel deployment use the
# "Connection Pooling" URI (port 6543). RLS is enforced through the
# anon/authenticated key flow. The web app must NOT use the service role.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres

# Bot HTTP API base URL. On Vercel, set this to the Railway public domain
# of the bot service (e.g. https://delfi-bot.up.railway.app). Locally, the
# bot runs on 127.0.0.1:8765.
BOT_API_URL=https://delfi-bot.up.railway.app

# Shared secret for dashboard -> bot HTTP auth. Must match BOT_API_SECRET
# in apps/bot. Generate with `openssl rand -base64 32`.
BOT_API_SECRET=

# Supabase project URL + anon key. Used by @supabase/ssr for session cookies,
# route gating in proxy.ts, and server actions in app/auth/actions.ts.
# Find these in Supabase dashboard -> Project Settings -> API.
# Project ref for this deployment: hvlbvbocgncgkkmawigu
NEXT_PUBLIC_SUPABASE_URL=https://hvlbvbocgncgkkmawigu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional -------------------------------------------------------------

# Shows a "Simulation mode" banner in the UI. Default: false.
# NEXT_PUBLIC_PAPER_MODE=true

# apps/bot/.env.example — Railway service environment.
#
# Copy to .env for local runs. On Railway, paste each variable into the
# service's Variables tab; Railway injects them into the process env.
#
# Required variables fail-fast at startup; optional ones degrade gracefully.

# --- Required --------------------------------------------------------------

# Supabase Postgres connection string. Use the "Connection Pooling" URI
# (pgbouncer, port 6543) for the Railway service. Service-role access —
# this connection bypasses RLS and reads/writes every user's rows.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres

# Claude API key (apps/bot/research/fetcher.py).
ANTHROPIC_API_KEY=sk-ant-...

# Gemini Flash API key (apps/bot/research/fetcher.py, feeds/news_feed.py).
GEMINI_API_KEY=...

# Shared secret for dashboard -> bot HTTP auth (apps/bot/bot_api.py). Must
# match BOT_API_SECRET in apps/web. Generate with `openssl rand -base64 32`.
BOT_API_SECRET=

# --- Polymarket live trading (required only for PM_MODE=live) -------------

# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# PROXY_ADDRESS=
# PRIVATE_KEY=

# --- Optional -------------------------------------------------------------

# Trading mode: shadow (simulated) or live. Default: shadow.
# PM_MODE=shadow

# Telegram alerts (apps/bot/feeds/telegram_notifier.py).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Extra news sources (apps/bot/feeds/news_feed.py, research/fetcher.py).
# CRYPTOPANIC_API_KEY=
# NEWSAPI_KEY=

# Logging verbosity. INFO or DEBUG.
# LOG_LEVEL=INFO

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Delfi window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/delfi-sidecar",
          "sidecar": true,
          "args": []
        }
      ]
    },
    "dialog:default",
    "opener:default"
  ]
}
